{
  "name": "anti-hallucination-mcp",
  "version": "0.13.0",
  "description": "Minimalist MCP server + hooks for anti-hallucination in AI coding assistants. Detects hallucinated symbols, typos in imports, and invalid API routes via AST-based fuzzy matching.",
  "type": "module",
  "license": "MIT",
  "main": "src/mcp-server/index.js",
  "bin": {
    "wisdom-store": "src/mcp-server/index.js",
    "anti-hallucination-mcp": "src/mcp-server/index.js",
    "anti-hallucination": "bin/cli.js"
  },
  "scripts": {
    "start": "node src/mcp-server/index.js",
    "setup": "node scripts/setup.js",
    "cli": "node bin/cli.js",
    "inspector": "npx @modelcontextprotocol/inspector node src/mcp-server/index.js",
    "test": "node --test",
    "lint": "eslint ."
  },
  "keywords": [
    "mcp",
    "claude",
    "anti-hallucination",
    "symbol-checking",
    "model-context-protocol",
    "codex",
    "antigravity",
    "gemini",
    "ai-safety",
    "ast",
    "tree-sitter"
  ],
  "author": "Akunimal",
  "homepage": "https://github.com/Akunimal/Anti-Hallucination-MCP#readme",
  "bugs": {
    "url": "https://github.com/Akunimal/Anti-Hallucination-MCP/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Akunimal/Anti-Hallucination-MCP.git"
  },
  "files": [
    "src/",
    "hooks/",
    "scripts/",
    "bin/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "@ast-grep/napi": "^0.33.0",
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "optionalDependencies": {
    "tree-sitter-python": "^0.23.0",
    "tree-sitter-go": "^0.23.0",
    "tree-sitter-rust": "^0.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "globals": "^17.6.0"
  }
}
